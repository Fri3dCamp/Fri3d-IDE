    "marked": "^15.0.7",
    "peerjs": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "toastr": "^2.1.4",
    "ua-parser-js": "^2.0.2",
    "web-serial-polyfill": "^1.0.15"

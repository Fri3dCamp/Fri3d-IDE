{
  "name": "Fri3d-IDE",
  "version": "0.5.2",
  "description": "An innovative MicroPython / CircuitPython IDE for Web and Mobile",
  "scripts": {
    "prepare-assets": "node scripts/prepare.mjs",
    "predev": "npm run prepare-assets",
    "dev": "vite",
    "prestart": "npm run prepare-assets",
    "start": "vite",
    "prebuild": "npm run prepare-assets",
    "build": "tsc && eslint . && vite build",
